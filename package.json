        "when": "editorTextFocus && miv.mode == 'NAV' && !miv.searchActive && !miv.replaceRuleInputActive && !miv.replaceCharPending"
      },
      {
        "key": "[KeyN]",
        "command": "miv.searchNext",
        "when": "editorTextFocus && miv.mode == 'NAV' && !miv.searchActive && !miv.replaceRuleInputActive && !miv.replaceCharPending"
      },
      {
        "key": "shift+[KeyN]",
        "command": "miv.searchPrevious",
        "when": "editorTextFocus && miv.mode == 'NAV' && !miv.searchActive && !miv.replaceRuleInputActive && !miv.replaceCharPending"
      },
      {
        "key": "backspace",
        "command": "miv.searchBackspace",
        "when": "editorTextFocus && (miv.searchActive || miv.replaceRuleInputActive)"
      },
      {
        "key": "alt+a",
        "command": "miv.executeBuiltin",
        "args": [
          "workbench.action.navigateBack"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+d",
        "command": "miv.executeBuiltin",
        "args": [
          "workbench.action.navigateForward"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+z",
        "command": "miv.setAnchor",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+x",
        "command": "miv.jumpToAnchor",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "ctrl+f",
        "command": "miv.executeBuiltin",
        "args": [
          "actions.find"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "ctrl+c",
        "command": "miv.copyToClipboard",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "cmd+c",
        "command": "miv.copyToClipboard",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "ctrl+v",
        "command": "miv.pasteFromClipboard",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "cmd+v",
        "command": "miv.pasteFromClipboard",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "escape",
        "command": "miv.toNavMode",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "generate-keymap": "node scripts/generateKeybindings.js",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "install-local": "bash scripts/install-vscode-extension.sh",
    "publish-marketplace": "bash scripts/publish-vscode-extension.sh",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
