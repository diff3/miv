{
  "name": "miv",
  "displayName": "MIV",
  "description": "Lightweight modal editing for VS Code inspired by Vim and designed for IDE workflows.",
  "version": "1.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diff3/miv"
  },
  "homepage": "https://github.com/diff3/miv",
  "bugs": {
    "url": "https://github.com/diff3/miv/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "miv.cursorLeft",
        "title": "MIV: Move Cursor Left"
      },
      {
        "command": "miv.cursorRight",
        "title": "MIV: Move Cursor Right"
      },
      {
        "command": "miv.cursorUp",
        "title": "MIV: Move Cursor Up"
      },
      {
        "command": "miv.pageUp",
        "title": "MIV: Page Up"
      },
      {
        "command": "miv.cursorDown",
        "title": "MIV: Move Cursor Down"
      },
      {
        "command": "miv.pageDown",
        "title": "MIV: Page Down"
      },
      {
        "command": "miv.lineStart",
        "title": "MIV: Move To Line Start"
      },
      {
        "command": "miv.lineEnd",
        "title": "MIV: Move To Line End"
      },
      {
        "command": "miv.wordLeft",
        "title": "MIV: Move Word Left"
      },
      {
        "command": "miv.wordEndRight",
        "title": "MIV: Move To Word End Right"
      },
      {
        "command": "miv.wordEndLeft",
        "title": "MIV: Move To Word End Left"
      },
      {
        "command": "miv.wordStartRight",
        "title": "MIV: Move To Word Start Right"
      },
      {
        "command": "miv.deleteChar",
        "title": "MIV: Delete Character"
      },
      {
        "command": "miv.deleteLine",
        "title": "MIV: Delete Line"
      },
      {
        "command": "miv.deleteWord",
        "title": "MIV: Delete Word"
      },
      {
        "command": "miv.yankWord",
        "title": "MIV: Yank Word"
      },
      {
        "command": "miv.spaceInput",
        "title": "MIV: Space Input"
      },
      {
        "command": "miv.textObjectAuto",
        "title": "MIV: Select Automatic Text Object"
      },
      {
        "command": "miv.replaceChar",
        "title": "MIV: Replace Character"
      },
      {
        "command": "miv.replaceWord",
        "title": "MIV: Replace Word"
      },
      {
        "command": "miv.toggleCaseChar",
        "title": "MIV: Toggle Character Case"
      },
      {
        "command": "miv.toggleCaseWord",
        "title": "MIV: Toggle Word Case"
      },
      {
        "command": "miv.repeatLastCommand",
        "title": "MIV: Repeat Last Command"
      },
      {
        "command": "miv.repeatLastCommandAlias",
        "title": "MIV: Repeat Last Command Alias"
      },
      {
        "command": "miv.enterInsert",
        "title": "MIV: Enter Insert Mode"
      },
      {
        "command": "miv.insertAtLineStart",
        "title": "MIV: Insert At Line Start"
      },
      {
        "command": "miv.insertAtLineEnd",
        "title": "MIV: Insert At Line End"
      },
      {
        "command": "miv.undo",
        "title": "MIV: Undo"
      },
      {
        "command": "miv.yankLine",
        "title": "MIV: Yank Line"
      },
      {
        "command": "miv.openLineBelow",
        "title": "MIV: Open Line Below"
      },
      {
        "command": "miv.openLineAbove",
        "title": "MIV: Open Line Above"
      },
      {
        "command": "miv.paste",
        "title": "MIV: Paste"
      },
      {
        "command": "miv.showRegistersKey",
        "title": "MIV: Show Registers"
      },
      {
        "command": "miv.replaceMatches",
        "title": "MIV: Replace Matches"
      },
      {
        "command": "miv.searchForward",
        "title": "MIV: Search Forward"
      },
      {
        "command": "miv.searchBackward",
        "title": "MIV: Search Backward"
      },
      {
        "command": "miv.searchRegex",
        "title": "MIV: Search Regex"
      },
      {
        "command": "miv.searchNext",
        "title": "MIV: Search Next Match"
      },
      {
        "command": "miv.searchPrevious",
        "title": "MIV: Search Previous Match"
      },
      {
        "command": "miv.gotoLine",
        "title": "MIV: Go To Line"
      },
      {
        "command": "miv.documentBottom",
        "title": "MIV: Go To Document Bottom"
      },
      {
        "command": "miv.toNavMode",
        "title": "MIV: Enter NAV Mode"
      },
      {
        "command": "miv.toggleMode",
        "title": "MIV: Toggle Mode"
      },
      {
        "command": "miv.copyToClipboard",
        "title": "MIV: Copy To Clipboard"
      },
      {
        "command": "miv.pasteFromClipboard",
        "title": "MIV: Paste From Clipboard"
      },
      {
        "command": "miv.storeRegister",
        "title": "MIV: Store Register"
      },
      {
        "command": "miv.showRegisters",
        "title": "MIV: Show Registers"
      },
      {
        "command": "miv.setAnchor",
        "title": "MIV: Set Anchor"
      },
      {
        "command": "miv.jumpToAnchor",
        "title": "MIV: Jump To Anchor"
      },
      {
        "command": "miv.showCommandStats",
        "title": "MIV: Show Command Stats"
      },
      {
        "command": "miv.searchBackspace",
        "title": "MIV: Search Backspace"
      },
      {
        "command": "miv.executeBuiltin",
        "title": "MIV: Execute Built-in Command"
      },
      {
        "command": "miv.toggleSearchHighlight",
        "title": "MIV: Toggle Search Highlight"
      }
    ],
    "keybindings": [
      {
        "key": "a",
        "command": "miv.cursorLeft",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "d",
        "command": "miv.cursorRight",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "w",
        "command": "miv.cursorUp",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+w",
        "command": "miv.pageUp",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "s",
        "command": "miv.cursorDown",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+s",
        "command": "miv.pageDown",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+a",
        "command": "miv.lineStart",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+d",
        "command": "miv.lineEnd",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "q",
        "command": "miv.wordLeft",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "e",
        "command": "miv.wordEndRight",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+q",
        "command": "miv.wordEndLeft",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+e",
        "command": "miv.wordStartRight",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "x",
        "command": "miv.deleteChar",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "b",
        "command": "miv.deleteLine",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+x",
        "command": "miv.deleteWord",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+y",
        "command": "miv.yankWord",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "space",
        "command": "miv.spaceInput",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+1",
        "command": "miv.textObjectAuto",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "r",
        "command": "miv.replaceChar",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+r",
        "command": "miv.replaceWord",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "§",
        "command": "miv.toggleCaseChar",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+§",
        "command": "miv.toggleCaseWord",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "c",
        "command": "miv.repeatLastCommand",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": ".",
        "command": "miv.repeatLastCommandAlias",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "i",
        "command": "miv.enterInsert",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+i",
        "command": "miv.insertAtLineStart",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "k",
        "command": "miv.insertAtLineEnd",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "u",
        "command": "miv.undo",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "y",
        "command": "miv.yankLine",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "o",
        "command": "miv.openLineBelow",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+o",
        "command": "miv.openLineAbove",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "p",
        "command": "miv.paste",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "v",
        "command": "miv.showRegistersKey",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "=",
        "command": "miv.replaceMatches",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "/",
        "command": "miv.searchForward",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "\\",
        "command": "miv.searchBackward",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": ",",
        "command": "miv.searchRegex",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "n",
        "command": "miv.searchNext",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+n",
        "command": "miv.searchPrevious",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "backspace",
        "command": "miv.searchBackspace",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "g",
        "command": "miv.gotoLine",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "shift+g",
        "command": "miv.documentBottom",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+a",
        "command": "miv.executeBuiltin",
        "args": [
          "workbench.action.navigateBack"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+d",
        "command": "miv.executeBuiltin",
        "args": [
          "workbench.action.navigateForward"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+z",
        "command": "miv.setAnchor",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "alt+x",
        "command": "miv.jumpToAnchor",
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "ctrl+f",
        "command": "miv.executeBuiltin",
        "args": [
          "actions.find"
        ],
        "when": "editorTextFocus && miv.mode == 'NAV'"
      },
      {
        "key": "ctrl+c",
        "command": "miv.copyToClipboard",
        "when": "editorTextFocus"
      },
      {
        "key": "cmd+c",
        "command": "miv.copyToClipboard",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+v",
        "command": "miv.pasteFromClipboard",
        "when": "editorTextFocus"
      },
      {
        "key": "cmd+v",
        "command": "miv.pasteFromClipboard",
        "when": "editorTextFocus"
      },
      {
        "key": "escape",
        "command": "miv.toNavMode",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
